# Sdkwork IM local PostgreSQL + Redis development profile.
# Copy this file to .env.postgres and change values for your local setup.
#
# ===========================================================================
# Storage provider selection
# ===========================================================================
# Controls which backend stores the realtime layer uses.
# - local-disk (default): JSON files under ${SDKWORK_IM_RUNTIME_DIR}/state/
# - postgresql:          PostgreSQL via canonical SDKWORK_IM_DATABASE_* fields
SDKWORK_IM_STORAGE_PROVIDER=postgresql

# ===========================================================================
# PostgreSQL (conversation truth + realtime stores)
# ===========================================================================
SDKWORK_IM_DATABASE_ENGINE=postgresql
SDKWORK_IM_DATABASE_HOST=127.0.0.1
SDKWORK_IM_DATABASE_PORT=5432
SDKWORK_IM_DATABASE_NAME=sdkwork_ai_dev
SDKWORK_IM_DATABASE_SCHEMA=sdkwork_ai_dev
SDKWORK_IM_DATABASE_USERNAME=sdkwork_ai_dev
SDKWORK_IM_DATABASE_PASSWORD=sdkworkdev123
SDKWORK_IM_DATABASE_SSL_MODE=disable
SDKWORK_IM_DATABASE_MAX_CONNECTIONS=10

# Derived connection URL used by local scripts and Rust runtime bridges.
SDKWORK_IM_DATABASE_URL=postgresql://sdkwork_ai_dev:sdkworkdev123@127.0.0.1:5432/sdkwork_ai_dev?sslmode=disable

# ===========================================================================
# sdkwork-database unified pool configuration (§33)
# ===========================================================================
# These env vars are consumed by sdkwork_database_config::DatabaseConfig::from_env()
# and feed into all PostgreSQL adapters via from_database_config().
#
# SDKWORK_IM_DATABASE_MODE=standalone
# SDKWORK_IM_DATABASE_TABLE_PREFIX=im_
# SDKWORK_IM_DATABASE_MIN_CONNECTIONS=1
# SDKWORK_IM_DATABASE_ACQUIRE_TIMEOUT=30
# SDKWORK_IM_DATABASE_IDLE_TIMEOUT=300
# SDKWORK_IM_DATABASE_MAX_LIFETIME=1800

# ===========================================================================
# Redis (realtime event windows, checkpoints, sequence allocator, cluster bus)
# ===========================================================================
SDKWORK_IM_REDIS_ENABLED=true
SDKWORK_IM_REDIS_HOST=127.0.0.1
SDKWORK_IM_REDIS_PORT=6379
SDKWORK_IM_REDIS_DATABASE=0
SDKWORK_IM_REDIS_KEY_PREFIX=chat
SDKWORK_IM_REDIS_TLS=false
SDKWORK_IM_REDIS_URL=redis://127.0.0.1:6379/0

# ===========================================================================
# Snowflake ID generator (required in multi-node deployments)
# ===========================================================================
# Each node MUST have a unique node_id (0-1023).
# When unset, defaults to node_id=0 (suitable for single-node).
SDKWORK_IM_ID_NODE_ID=0

# ===========================================================================
# Runtime directory (persistent state for file-based stores)
# ===========================================================================
# When set, uses file-based persistence for journal/snapshots.
# When unset, runs in memory-only mode (suitable for tests).
SDKWORK_IM_RUNTIME_DIR=./.runtime/self-hosted.split-services.development

# ===========================================================================
# Admin database credentials (for pnpm db:postgres:init / migrations)
# ===========================================================================
SDKWORK_IM_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_IM_DATABASE_ADMIN_PASSWORD=postgres_admin_pass
SDKWORK_IM_DATABASE_ADMIN_SSL_MODE=disable
SDKWORK_IM_DATABASE_ADMIN_URL=postgresql://postgres:postgres_admin_pass@127.0.0.1:5432/postgres?sslmode=disable
