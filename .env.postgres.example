# Sdkwork IM local PostgreSQL + Redis development profile.
# Copy this file to .env.postgres and change values for your local setup.
#
# PostgreSQL connection identity is unified across all SDKWork applications.
# See sdkwork-specs/ENVIRONMENT_SPEC.md §7.1 and sdkwork-claw-router/.env.postgres.example.

# ===========================================================================
# Storage provider selection
# ===========================================================================
SDKWORK_IM_STORAGE_PROVIDER=postgresql

# ===========================================================================
# Unified workspace PostgreSQL profile
# ===========================================================================
SDKWORK_IM_DATABASE_ENGINE=postgresql
SDKWORK_IM_DATABASE_HOST=127.0.0.1
SDKWORK_IM_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_PASSWORD=sdkworkdev123
SDKWORK_IM_DATABASE_SSL_MODE=disable
SDKWORK_IM_DATABASE_MAX_CONNECTIONS=10

# ===========================================================================
# Redis (realtime event windows, checkpoints, sequence allocator, cluster bus)
# ===========================================================================
SDKWORK_IM_REDIS_ENABLED=true
SDKWORK_IM_REDIS_HOST=127.0.0.1
SDKWORK_IM_REDIS_PORT=6379
SDKWORK_IM_REDIS_DATABASE=0
SDKWORK_IM_REDIS_KEY_PREFIX=chat
SDKWORK_IM_REDIS_TLS=false
SDKWORK_IM_REDIS_URL=redis://127.0.0.1:6379/0

# Optional Redis-backed realtime route store / cluster bus (multi-node or HA dev).
# When either URL below is set, you must also set SDKWORK_IM_REALTIME_NODE_ID and
# SDKWORK_IM_REALTIME_CLUSTER_BUS_SECRET (default node id is rejected in cluster mode).
# SDKWORK_IM_REALTIME_ROUTE_STORE_URL=redis://127.0.0.1:6379/0
# SDKWORK_IM_REALTIME_CLUSTER_BUS_URL=redis://127.0.0.1:6379/0
# SDKWORK_IM_REALTIME_CLUSTER_BUS_SECRET=replace-with-strong-shared-secret
# SDKWORK_IM_REALTIME_NODE_ID=session_gateway_dev_1

# ===========================================================================
# Snowflake ID generator (required in multi-node deployments)
# ===========================================================================
SDKWORK_IM_ID_NODE_ID=0

# ===========================================================================
# Runtime directory (persistent state for file-based stores)
# ===========================================================================
SDKWORK_IM_RUNTIME_DIR=./.runtime/standalone.unified-process.development

# ===========================================================================
# Admin database credentials (for pnpm db:postgres:init / migrations)
# ===========================================================================
SDKWORK_IM_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_IM_DATABASE_ADMIN_PASSWORD=postgres_admin_pass
SDKWORK_IM_DATABASE_ADMIN_DATABASE=postgres
SDKWORK_IM_DATABASE_ADMIN_SSL_MODE=disable
SDKWORK_IM_DATABASE_ADMIN_URL=postgresql://postgres:postgres_admin_pass@127.0.0.1:5432/postgres?sslmode=disable

# ===========================================================================
# Retention purge scheduler (PostgreSQL-backed deployments)
# ===========================================================================
# Enabled by default when SDKWORK_IM_DATABASE_URL is set. Uses a PostgreSQL
# advisory lock so only one process purges expired rows per database.
SDKWORK_IM_RETENTION_PURGE_SCHEDULER_ENABLED=true
SDKWORK_IM_RETENTION_PURGE_INTERVAL_SECONDS=3600
SDKWORK_IM_RETENTION_PURGE_BATCH_SIZE=500
SDKWORK_IM_RETENTION_PURGE_MAX_BATCHES_PER_TICK=100

# ===========================================================================
# Shared-channel sync stale-claim reclaim (comms-social-service)
# ===========================================================================
SDKWORK_IM_SHARED_CHANNEL_SYNC_STALE_RECLAIM_SCHEDULER_ENABLED=true
SDKWORK_IM_SHARED_CHANNEL_SYNC_STALE_RECLAIM_INTERVAL_SECONDS=60

# ===========================================================================
# Embedded IAM tenant signing KEK (required for IAM session/token issuance)
# ===========================================================================
# Encrypts iam_tenant_signing_key.secret_ref at rest. Per-tenant JWT signing
# material is stored in PostgreSQL; this env var is the deployment master key.
# When multiple SDKWork apps share sdkwork_ai_dev, keep the same value everywhere.
SDKWORK_IAM_TENANT_SIGNING_MASTER_SECRET=sdkwork-im-dev-tenant-signing-master-secret-v1

# ===========================================================================
# OpenTelemetry export (optional; OBSERVABILITY_SPEC §4)
# ===========================================================================
# When set, IM service processes export traces via sdkwork-web-bootstrap otel feature.
# OTEL_SERVICE_NAME defaults to each process identity when unset.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
