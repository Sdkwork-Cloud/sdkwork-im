# Sdkwork IM local PostgreSQL development profile.
# Copy this file to .env.postgres and change values for your local database.

SDKWORK_IM_DEPLOYMENT_MODE=server
SDKWORK_IM_DATABASE_ENGINE=postgresql
SDKWORK_IM_DATABASE_HOST=127.0.0.1
SDKWORK_IM_DATABASE_PORT=5432
SDKWORK_IM_DATABASE_NAME=sdkwork_ai_dev
SDKWORK_IM_DATABASE_SCHEMA=sdkwork_ai_dev
SDKWORK_IM_DATABASE_USERNAME=sdkwork_ai_dev
SDKWORK_IM_DATABASE_PASSWORD=sdkworkdev123
SDKWORK_IM_DATABASE_SSL_MODE=disable
SDKWORK_IM_DATABASE_MAX_CONNECTIONS=10

SDKWORK_IM_REDIS_ENABLED=true
SDKWORK_IM_REDIS_HOST=127.0.0.1
SDKWORK_IM_REDIS_PORT=6379
SDKWORK_IM_REDIS_DATABASE=0
SDKWORK_IM_REDIS_KEY_PREFIX=chat
SDKWORK_IM_REDIS_TLS=false

# Optional: direct app connection URL. If set, it takes precedence over split app fields.
# Keep this commented unless you need to test a full URL explicitly.
# SDKWORK_IM_DATABASE_URL=postgresql://sdkwork_ai_dev:sdkworkdev123@127.0.0.1:5432/sdkwork_ai_dev?sslmode=disable

# Required for pnpm db:postgres:init because creating roles/databases needs an admin connection.
# pnpm db:postgres:migrate only needs the app account above.
SDKWORK_IM_DATABASE_ADMIN_HOST=127.0.0.1
SDKWORK_IM_DATABASE_ADMIN_PORT=5432
SDKWORK_IM_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_IM_DATABASE_ADMIN_PASSWORD=postgres_admin_pass
SDKWORK_IM_DATABASE_ADMIN_DATABASE=postgres
SDKWORK_IM_DATABASE_ADMIN_SSL_MODE=disable

# Optional: direct admin connection URL. If set, it takes precedence over split admin fields.
# SDKWORK_IM_DATABASE_ADMIN_URL=postgresql://postgres:postgres_admin_pass@127.0.0.1:5432/postgres?sslmode=disable
