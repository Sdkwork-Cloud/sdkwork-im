# Docker build context exclusions for SDKWork IM.
# Reduces build context size and speeds up docker build.

# Build artifacts and caches
target/
.runtime/cargo-target/
**/target/
**/*.rs.bk

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Git
.git/
.gitignore
.github/

# Documentation (not needed in Docker build context)
docs/
*.md
!Cargo.toml
!Cargo.lock

# Node.js (not needed for Rust Docker build)
node_modules/
**/node_modules/
**/dist/
**/.turbo/

# Test artifacts
**/tests/
**/*.test.ts
**/*.test.tsx
**/*.test.mjs
**/*.test.js

# Runtime and deployment files not needed during build
deployments/kubernetes/
deployments/observability/
deployments/templates/quickstart-server-compose.env.example

# CI and scripts
.mimocode/
.sdkwork/
specs/
tools/chat-cli/

# Misc
.env*
*.log
