{
  "name": "@sdkwork/craw-chat-sdk",
  "version": "0.1.0",
  "description": "Composed Craw Chat TypeScript SDK built on the generated app backend SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@sdkwork/craw-chat-backend-sdk": "file:../generated/server-openapi"
  },
  "scripts": {
    "typecheck": "node ./bin/run-tsc.mjs -p tsconfig.build.json --noEmit",
    "build": "node ./bin/run-tsc.mjs -p tsconfig.build.json && node ./bin/clean-dist.mjs",
    "test": "node ./test/craw-chat-client.test.mjs"
  }
}
