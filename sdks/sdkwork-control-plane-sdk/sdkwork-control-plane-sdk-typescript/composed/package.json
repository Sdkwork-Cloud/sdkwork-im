{
  "name": "@sdkwork/control-plane-sdk",
  "version": "0.1.0",
  "description": "Composed control-plane TypeScript SDK built on the generated control-plane backend SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@sdkwork/control-plane-backend-sdk": "file:../generated/server-openapi",
    "sdkwork-control-plane-types": "file:../../../../apps/craw-chat-admin/packages/sdkwork-control-plane-types"
  },
  "scripts": {
    "typecheck": "node ../../bin/build-control-plane-types-stubs.mjs && node ./bin/run-tsc.mjs -p tsconfig.build.json --noEmit",
    "build": "node ../../bin/build-control-plane-types-stubs.mjs && node ./bin/run-tsc.mjs -p tsconfig.build.json && node ./bin/clean-dist.mjs",
    "test": "node ./test/control-plane-client.test.mjs"
  }
}
