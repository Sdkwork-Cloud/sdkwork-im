    "appApiSdkFamily": "sdkwork-im-app-sdk",
    "backendApiSdkFamily": "sdkwork-im-backend-sdk"
  },
  "inspectionPolicy": {
    "mode": "convention",
    "protocol": "rpc",
    "optionalControlPlane": {
      "emitFlag": "--emit-control-plane",
      "purpose": [
        "release",
        "ci",
        "audit",
        "migration"
      ]
    }
  },
