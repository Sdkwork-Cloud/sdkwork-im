{
  "workspace": "sdkwork-im-rpc-sdk",
  "title": "SDKWork IM RPC SDK",
  "domain": "communication",
  "capability": "chat",
  "apiVersion": "0.1.0",
  "protoVersion": "v3",
  "rpcManifest": "rpc/sdkwork-im-rpc.manifest.json",
