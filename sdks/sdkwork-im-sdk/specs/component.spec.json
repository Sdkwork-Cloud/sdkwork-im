{
  "schemaVersion": 1,
  "kind": "sdkwork.component.spec",
  "component": {
    "name": "sdkwork-im-sdk",
    "displayName": "SDKWork IM SDK",
    "version": "0.1.0",
    "type": "sdk-family",
    "root": "sdkwork-im/sdks/sdkwork-im-sdk",
    "domain": "communication",
    "declaredDomain": null,
    "capability": "im",
    "status": "standardizing",
    "languages": [
      "csharp",
      "flutter",
      "go",
      "java",
      "kotlin",
      "python",
      "rust",
      "swift",
      "typescript"
    ],
    "generated": true,
    "private": false,
    "manifests": [
      ".sdkwork-assembly.json"
    ]
  },
  "canonicalSpecs": [
    {
      "file": "API_SPEC.md",
      "path": "../../../sdkwork-specs/API_SPEC.md",
      "purpose": "HTTP/OpenAPI and generated SDK contract rules."
    },
    {
      "file": "COMPONENT_SPEC.md",
      "path": "../../../sdkwork-specs/COMPONENT_SPEC.md",
      "purpose": "Local component specs directory and manifest rules."
    },
    {
      "file": "SDK_SPEC.md",
      "path": "../../../sdkwork-specs/SDK_SPEC.md",
      "purpose": "SDK generation and SDK integration rules."
    },
    {
      "file": "SDK_WORKSPACE_GENERATION_SPEC.md",
      "path": "../../../sdkwork-specs/SDK_WORKSPACE_GENERATION_SPEC.md",
      "purpose": "Application-root sdks workspace, SDK family naming, API authority naming, and OpenAPI generation rules."
    },
    {
      "file": "TEST_SPEC.md",
      "path": "../../../sdkwork-specs/TEST_SPEC.md",
      "purpose": "Contract, frontend, SDK, security, parity, and documentation verification rules."
    },
    {
      "file": "CODE_STYLE_SPEC.md",
      "path": "../../../sdkwork-specs/CODE_STYLE_SPEC.md",
      "purpose": "Authored source structure and generated code boundaries."
    },
    {
      "file": "NAMING_SPEC.md",
      "path": "../../../sdkwork-specs/NAMING_SPEC.md",
      "purpose": "Canonical SDKWork naming rules."
    },
    {
      "file": "TYPESCRIPT_CODE_SPEC.md",
      "path": "../../../sdkwork-specs/TYPESCRIPT_CODE_SPEC.md",
      "purpose": "TypeScript and Node package rules."
    }
  ],
  "contracts": {
    "apiAuthority": {
      "name": "sdkwork-im-open-api",
      "prefix": "/im/v3/api",
      "authorityOpenApi": "openapi/sdkwork-im-im.openapi.yaml",
      "derivedOpenApi": [
        "openapi/sdkwork-im-im.sdkgen.yaml",
        "openapi/sdkwork-im-im.flutter.sdkgen.yaml"
      ],
      "standard": "../../../sdkwork-specs/SDK_WORKSPACE_GENERATION_SPEC.md"
    },
    "publicExports": [
      "@sdkwork/im-sdk"
    ],
    "runtimeEntrypoints": [
      ".sdkwork-assembly.json"
    ],
    "sdkDependencies": [],
    "sdkClients": [
      "SdkworkImClient",
      "ImSdkClient"
    ],
    "events": [],
    "configKeys": [
      ".sdkwork-assembly.json"
    ],
    "routeManifest": null
  },
  "integration": {
    "authority": "Root SDKWork specs remain authoritative. Local specs may extend but must not contradict them.",
    "dependencyPolicy": "Consumers integrate through public package exports, declared runtime entrypoints, generated SDK clients, or documented adapters only.",
    "sdkPolicy": "Generated SDK clients are injected through service/runtime boundaries; reusable UI must not create raw HTTP clients or manual auth headers.",
    "languagePolicy": "Language-specific packages follow their native manifest and build tools while preserving the same component contract."
  },
  "verification": {
    "commands": [
      "node sdks/sdkwork-im-sdk/bin/verify-sdk.mjs"
    ]
  },
  "metadata": {
    "managedBy": "sdkwork-im-sdk",
    "standardVersion": "2026-05-13"
  }
}
