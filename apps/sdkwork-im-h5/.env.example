# Sdkwork IM H5 renderer — optional local overrides.
# Full stack development uses repository-root topology profiles:
#   pnpm dev

# Application ingress (default from configs/topology/standalone.unified-process.development.env)
VITE_SDKWORK_IM_H5_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18079
VITE_SDKWORK_IM_H5_APPLICATION_PUBLIC_WEBSOCKET_URL=ws://127.0.0.1:18079

# Platform API gateway (IAM) — collapsed to application ingress in standalone dev
VITE_SDKWORK_IAM_APP_API_BASE_URL=http://127.0.0.1:18079

# SDKWork private bootstrap credential (blank in tracked files).
SDKWORK_ACCESS_TOKEN=
