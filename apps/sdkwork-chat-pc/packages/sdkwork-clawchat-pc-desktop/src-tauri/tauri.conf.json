{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SDKWork Chat PC",
  "version": "0.1.0",
  "identifier": "com.sdkwork.chatpc",
  "build": {
    "beforeDevCommand": "pnpm dev:tauri",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../../../dist",
    "devUrl": "http://127.0.0.1:4176"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SDKWork Chat PC",
        "decorations": false,
        "center": true,
        "minWidth": 1200,
        "minHeight": 760,
        "width": 1440,
        "height": 960
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": "((mailto:\\w+)|(tel:\\w+)|(https?://\\w+).+|(file://.+)|([A-Za-z]:\\\\.+)|(\\\\\\\\.+))"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
