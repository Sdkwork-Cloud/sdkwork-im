{
  "name": "@sdkwork/ui-pc-react",
  "version": "0.1.0",
  "description": "SDKWORK shared PC React UI framework built on shadcn-style primitives and desktop application patterns.",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/src/theme/index.d.ts",
      "import": "./dist/theme.js"
    },
    "./components/ui": {
      "types": "./dist/src/components/ui/index.d.ts",
      "import": "./dist/components-ui.js"
    },
    "./components/ui/actions": {
      "types": "./dist/src/components/ui/actions/index.d.ts",
      "import": "./dist/ui-actions.js"
    },
    "./components/ui/data-entry": {
      "types": "./dist/src/components/ui/data-entry/index.d.ts",
      "import": "./dist/ui-data-entry.js"
    },
    "./components/ui/data-display": {
      "types": "./dist/src/components/ui/data-display/index.d.ts",
      "import": "./dist/ui-data-display.js"
    },
