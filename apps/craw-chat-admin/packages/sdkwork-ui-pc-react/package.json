      "types": "./dist/src/components/patterns/detail/index.d.ts",
      "import": "./dist/patterns-detail.js"
    },
    "./components/patterns/picker": {
      "types": "./dist/src/components/patterns/picker/index.d.ts",
      "import": "./dist/patterns-picker.js"
    },
    "./components/patterns/settings": {
      "types": "./dist/src/components/patterns/settings/index.d.ts",
      "import": "./dist/patterns-settings.js"
    },
    "./components/patterns/system": {
      "types": "./dist/src/components/patterns/system/index.d.ts",
      "import": "./dist/patterns-system.js"
    },
    "./components/patterns/workbench": {
      "types": "./dist/src/components/patterns/workbench/index.d.ts",
      "import": "./dist/patterns-workbench.js"
    },
    "./components/patterns/workspace": {
      "types": "./dist/src/components/patterns/workspace/index.d.ts",
      "import": "./dist/patterns-workspace.js"
    },
    "./styles.css": "./dist/sdkwork-ui.css"
  },
  "scripts": {
    "build": "./scripts/run-vite-build.cmd",
    "prepare": "./scripts/run-vite-build.cmd",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "docs:dev": "node scripts/run-vitepress.mjs dev docs --host 127.0.0.1 --port 4175",
    "docs:build": "node scripts/run-vitepress.mjs build docs",
    "docs:preview": "node scripts/run-vitepress.mjs preview docs --host 127.0.0.1 --port 4176"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0",
