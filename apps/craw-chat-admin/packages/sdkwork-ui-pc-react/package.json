      "types": "./dist/src/components/ui/overlays/index.d.ts",
      "import": "./dist/ui-overlays.js"
    },
    "./components/ui/catalog": {
      "types": "./dist/src/components/ui/catalog.d.ts",
      "import": "./dist/ui-catalog.js"
    },
    "./components/patterns": {
      "types": "./dist/src/components/patterns/index.d.ts",
      "import": "./dist/components-patterns.js"
    },
    "./components/patterns/app-shell": {
      "types": "./dist/src/components/patterns/app-shell/index.d.ts",
      "import": "./dist/patterns-app-shell.js"
