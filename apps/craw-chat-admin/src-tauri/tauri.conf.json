{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Craw Chat Admin",
  "version": "0.1.0",
  "identifier": "com.sdkwork.router.admin",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "node ../../scripts/build-router-desktop-assets.mjs",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173/admin/"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist/": "embedded-sites/admin/",
      "../../sdkwork-router-portal/dist/": "embedded-sites/portal/"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Craw Chat Admin",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "decorations": false
      }
    ]
  }
}
