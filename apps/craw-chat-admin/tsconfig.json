    "packages/sdkwork-craw-chat-admin-settings/src/index.tsx",
    "packages/sdkwork-craw-chat-admin-shell/src/**/*.ts",
    "packages/sdkwork-craw-chat-admin-shell/src/**/*.tsx",
    "packages/sdkwork-craw-chat-admin-types/src/**/*.ts"
