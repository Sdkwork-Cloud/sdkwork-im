      "@sdkwork/ui-pc-react/*": ["../../../../../sdkwork-ui/sdkwork-ui-pc-react/dist/*"],
      "@sdkwork/ui-pc-react/styles.css": [
        "../../../../../sdkwork-ui/sdkwork-ui-pc-react/dist/sdkwork-ui.css"
      ],
      "@sdkwork/craw-chat-sdk-management": [
        "../../sdks/sdkwork-craw-chat-sdk-management/sdkwork-craw-chat-sdk-management-typescript/composed/src/index.ts"
      ],
