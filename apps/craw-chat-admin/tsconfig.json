{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "motion/react": ["src/vendor/motion-react.tsx"],
      "@sdkwork/ui-pc-react": ["src/types/sdkwork-ui-pc-react-shim.d.ts"],
      "@sdkwork/ui-pc-react/theme": ["packages/sdkwork-ui-pc-react/dist/theme/index.d.ts"],
      "@sdkwork/ui-pc-react/*": ["packages/sdkwork-ui-pc-react/dist/*"],
      "@sdkwork/ui-pc-react/styles.css": [
        "packages/sdkwork-ui-pc-react/dist/sdkwork-ui.css"
      ],
      "@sdkwork/control-plane-sdk": [
        "../../sdks/sdkwork-control-plane-sdk/sdkwork-control-plane-sdk-typescript/composed/src/index.ts"
      ],
      "@sdkwork/im-admin-backend-sdk": [
        "../../sdks/sdkwork-im-admin-sdk/sdkwork-im-admin-sdk-typescript/generated/server-openapi/src/index.ts"
      ],
      "@sdkwork/sdk-common": [
        "../../sdk/sdkwork-sdk-commons/sdkwork-sdk-common-typescript/dist/index.d.ts"
      ],
      "sdkwork-control-plane-conversations": ["packages/sdkwork-control-plane-conversations/src/index.tsx"],
      "sdkwork-control-plane-auth": ["packages/sdkwork-control-plane-auth/src/index.tsx"],
      "sdkwork-control-plane-groups": ["packages/sdkwork-control-plane-groups/src/index.tsx"],
      "sdkwork-control-plane-automation": ["packages/sdkwork-control-plane-automation/src/index.tsx"],
      "sdkwork-control-plane-core": ["packages/sdkwork-control-plane-core/src/index.tsx"],
      "sdkwork-control-plane-moderation": ["packages/sdkwork-control-plane-moderation/src/index.tsx"],
      "sdkwork-control-plane-system": ["packages/sdkwork-control-plane-system/src/index.tsx"],
      "sdkwork-control-plane-overview": ["packages/sdkwork-control-plane-overview/src/index.tsx"],
      "sdkwork-control-plane-announcements": ["packages/sdkwork-control-plane-announcements/src/index.tsx"],
      "sdkwork-control-plane-realtime": ["packages/sdkwork-control-plane-realtime/src/index.tsx"],
      "sdkwork-control-plane-settings": ["packages/sdkwork-control-plane-settings/src/index.tsx"],
      "sdkwork-control-plane-shell": ["packages/sdkwork-control-plane-shell/src/index.ts"],
      "sdkwork-control-plane-storage": ["packages/sdkwork-control-plane-storage/src/index.tsx"],
      "sdkwork-control-plane-tenants": ["packages/sdkwork-control-plane-tenants/src/index.tsx"],
      "sdkwork-control-plane-messages": ["packages/sdkwork-control-plane-messages/src/index.tsx"],
      "sdkwork-control-plane-types": ["packages/sdkwork-control-plane-types/src/index.ts"],
      "sdkwork-control-plane-users": ["packages/sdkwork-control-plane-users/src/index.tsx"]
    }
  },
  "include": [
    "src",
    "vite.config.ts",
    "packages/sdkwork-control-plane-auth/src/**/*.tsx",
    "packages/sdkwork-control-plane-core/src/**/*.ts",
    "packages/sdkwork-control-plane-core/src/**/*.tsx",
    "packages/sdkwork-control-plane-overview/src/index.tsx",
    "packages/sdkwork-control-plane-tenants/src/index.tsx",
    "packages/sdkwork-control-plane-users/src/index.tsx",
    "packages/sdkwork-control-plane-conversations/src/index.tsx",
    "packages/sdkwork-control-plane-messages/src/index.tsx",
    "packages/sdkwork-control-plane-groups/src/index.tsx",
    "packages/sdkwork-control-plane-moderation/src/index.tsx",
    "packages/sdkwork-control-plane-automation/src/index.tsx",
    "packages/sdkwork-control-plane-announcements/src/index.tsx",
    "packages/sdkwork-control-plane-realtime/src/index.tsx",
    "packages/sdkwork-control-plane-system/src/index.tsx",
    "packages/sdkwork-control-plane-storage/src/**/*.ts",
    "packages/sdkwork-control-plane-storage/src/**/*.tsx",
    "packages/sdkwork-control-plane-settings/src/index.tsx",
    "packages/sdkwork-control-plane-shell/src/**/*.ts",
    "packages/sdkwork-control-plane-shell/src/**/*.tsx",
    "packages/sdkwork-control-plane-types/src/**/*.ts"
  ],
  "exclude": ["packages/**/node_modules/**"]
}
