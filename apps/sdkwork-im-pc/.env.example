# Sdkwork IM PC renderer — optional local overrides.
# Full stack development uses repository-root topology profiles:
#   pnpm dev
#   pnpm dev:desktop

# Application ingress (default from configs/topology/standalone.unified-process.development.env)
VITE_SDKWORK_IM_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18079
VITE_SDKWORK_IM_APPLICATION_PUBLIC_WEBSOCKET_URL=ws://127.0.0.1:18079

# Platform API gateway (IAM, Drive, Agent, Notary) — collapsed to application ingress in standalone dev
VITE_SDKWORK_IM_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:18079
VITE_SDKWORK_IAM_APP_API_BASE_URL=http://127.0.0.1:18079

# Optional: disable Vite HMR during automated edits
# DISABLE_HMR=true

# SDKWork private bootstrap credential (blank in tracked files).
SDKWORK_ACCESS_TOKEN=
