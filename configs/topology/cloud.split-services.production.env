# cloud.split-services.production
SDKWORK_IM_DEPLOYMENT_PROFILE=cloud
SDKWORK_IM_SERVICE_LAYOUT=split-services
SDKWORK_IM_ENVIRONMENT=production
SDKWORK_IM_PROFILE_ID=cloud.split-services.production

SDKWORK_IM_APPLICATION_PUBLIC_HTTP_URL=https://im.sdkwork.com
SDKWORK_IM_APPLICATION_PUBLIC_WEBSOCKET_URL=wss://im.sdkwork.com
SDKWORK_IM_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
SDKWORK_IM_PLATFORM_API_GATEWAY_AUTOSTART=false

SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=db.example.com
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_PASSWORD_FILE=/run/secrets/sdkwork/database-password
SDKWORK_CLAW_DATABASE_SSL_MODE=require
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=32

VITE_SDKWORK_IM_DEPLOYMENT_PROFILE=cloud
VITE_SDKWORK_IM_APPLICATION_PUBLIC_HTTP_URL=https://im.sdkwork.com
VITE_SDKWORK_IM_APPLICATION_PUBLIC_WEBSOCKET_URL=wss://im.sdkwork.com
VITE_SDKWORK_IM_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com

# Optional session-gateway HA (multi-node realtime plane)
# SDKWORK_IM_INTERNAL_SESSION_GATEWAY_BIND=127.0.0.1:18080
# SDKWORK_IM_REALTIME_NODE_ID=session_gateway_prod_1
# SDKWORK_IM_REALTIME_CLUSTER_BUS_SECRET=/run/secrets/sdkwork/realtime-cluster-bus-secret
# SDKWORK_IM_REALTIME_CLUSTER_BUS_URL=redis://redis.internal:6379
# SDKWORK_IM_DATABASE_URL=postgres://sdkwork@db.example.com:5432/sdkwork
# SDKWORK_IM_SESSION_GATEWAY_RPC_BIND_ADDR=127.0.0.1:50051
# SDKWORK_IM_SESSION_GATEWAY_RPC_PUBLIC_ENDPOINT=http://session-gateway-rpc.internal:50051

# Security hardening (see deployments/templates/server.env.example)
SDKWORK_IM_APP_CONTEXT_REQUIRE_SIGNATURE=true
SDKWORK_IM_APP_CONTEXT_SIGNATURE_SECRET_FILE=/run/secrets/sdkwork/app-context-signature-secret
SDKWORK_IM_APP_CONTEXT_JWT_TENANT_ID=100001
SDKWORK_IM_APP_CONTEXT_JWT_KEY_ID=bootstrap
SDKWORK_IM_APP_CONTEXT_JWT_SIGNING_SECRET_FILE=/run/secrets/sdkwork/jwt-signing-secret
SDKWORK_API_CLOUD_GATEWAY_CONFIG=configs/sdkwork-api-cloud-gateway.sdkwork-im.production.toml
