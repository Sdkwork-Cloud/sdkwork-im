# standalone.unified-process.production
SDKWORK_IM_DEPLOYMENT_PROFILE=standalone
SDKWORK_IM_SERVICE_LAYOUT=unified-process
SDKWORK_IM_ENVIRONMENT=production
SDKWORK_IM_PROFILE_ID=standalone.unified-process.production

SDKWORK_IM_APPLICATION_PUBLIC_INGRESS_BIND=0.0.0.0:18079
SDKWORK_IM_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18079
SDKWORK_IM_APPLICATION_PUBLIC_WEBSOCKET_URL=ws://127.0.0.1:18079
SDKWORK_IM_STANDALONE_GATEWAY_ENVIRONMENT=production
SDKWORK_IM_PLATFORM_API_GATEWAY_AUTOSTART=true

SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=db.example.com
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_PASSWORD_FILE=/etc/sdkwork/router/database.secret
SDKWORK_CLAW_DATABASE_SSL_MODE=require
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=20

VITE_SDKWORK_IM_DEPLOYMENT_PROFILE=standalone
VITE_SDKWORK_IM_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18079
VITE_SDKWORK_IM_APPLICATION_PUBLIC_WEBSOCKET_URL=ws://127.0.0.1:18079
VITE_SDKWORK_IM_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:18079

# Security hardening (see deployments/templates/server.env.example)
SDKWORK_IM_APP_CONTEXT_REQUIRE_SIGNATURE=true
SDKWORK_IM_APP_CONTEXT_SIGNATURE_SECRET_FILE=/etc/sdkwork/chat/app-context-signature.secret
SDKWORK_IM_APP_CONTEXT_JWT_TENANT_ID=100001
SDKWORK_IM_APP_CONTEXT_JWT_KEY_ID=bootstrap
SDKWORK_IM_APP_CONTEXT_JWT_SIGNING_SECRET_FILE=/etc/sdkwork/chat/jwt-signing.secret
