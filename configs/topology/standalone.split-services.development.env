# standalone.split-services.development
SDKWORK_IM_DEPLOYMENT_PROFILE=standalone
SDKWORK_IM_SERVICE_LAYOUT=split-services
SDKWORK_IM_ENVIRONMENT=development
SDKWORK_IM_PROFILE_ID=standalone.split-services.development

SDKWORK_IM_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:18079
SDKWORK_IM_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18079
SDKWORK_IM_APPLICATION_PUBLIC_WEBSOCKET_URL=ws://127.0.0.1:18079
SDKWORK_IM_STANDALONE_GATEWAY_ENVIRONMENT=development
SDKWORK_IM_PLATFORM_API_GATEWAY_AUTOSTART=true

# Per-tenant JWT signing keys are provisioned in iam_tenant_signing_key during tenant bootstrap.

SDKWORK_API_CLOUD_GATEWAY_BIND=127.0.0.1:18079
SDKWORK_IM_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:18079

VITE_SDKWORK_IM_DEPLOYMENT_PROFILE=standalone
VITE_SDKWORK_IM_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18079
VITE_SDKWORK_IM_APPLICATION_PUBLIC_WEBSOCKET_URL=ws://127.0.0.1:18079
VITE_SDKWORK_IM_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:18079

SDKWORK_IM_INTERNAL_SESSION_GATEWAY_BIND=127.0.0.1:18080
# Optional: co-locate session-gateway inside the public gateway process (single-node split dev)
# SDKWORK_IM_GATEWAY_EMBED_REALTIME_PLANE=true
# Optional session-gateway HA (multi-node realtime plane)
# Realtime cluster routing (required when Redis route store / cluster bus is enabled)
# SDKWORK_IM_REALTIME_NODE_ID=session_gateway_dev_1
# SDKWORK_IM_REALTIME_CLUSTER_BUS_SECRET=replace-with-strong-shared-secret
# SDKWORK_IM_REALTIME_CLUSTER_BUS_URL=redis://127.0.0.1:6379
# SDKWORK_IM_DATABASE_URL=postgres://chat_user:chat_pass@127.0.0.1:5432/chat
# SDKWORK_IM_REALTIME_MAX_WEBSOCKET_CONNECTIONS=10000
# SDKWORK_IM_SESSION_GATEWAY_MAX_IN_FLIGHT_REQUESTS=2000
# SDKWORK_IM_SESSION_GATEWAY_MAX_REQUEST_BODY_BYTES=5242880
# Optional session-gateway RPC Phase 1 host
# SDKWORK_IM_SESSION_GATEWAY_RPC_BIND_ADDR=127.0.0.1:50051
# SDKWORK_IM_SESSION_GATEWAY_RPC_PUBLIC_ENDPOINT=http://127.0.0.1:50051
# Optional comms-conversation RPC Phase 1 host
# SDKWORK_IM_COMMS_CONVERSATION_RPC_BIND_ADDR=127.0.0.1:50052
# SDKWORK_IM_COMMS_CONVERSATION_RPC_PUBLIC_ENDPOINT=http://127.0.0.1:50052
# SDKWORK_IM_COMMS_CONVERSATION_INTERNAL_RPC_BIND_ADDR=127.0.0.1:50053
# SDKWORK_IM_COMMS_CONVERSATION_INTERNAL_RPC_PUBLIC_ENDPOINT=http://127.0.0.1:50053
# SDKWORK_IM_DISCOVERY_SERVICE_NAME=sdkwork-communication-internal-rpc
# Optional link-plane TCP/UDP acceptors (CCP ccp/tcp/1 and ccp/udp/1)
# Route store resolution: Redis+Postgres tier (when both set) > Redis > Postgres (SDKWORK_IM_DATABASE_URL) > memory
# SDKWORK_IM_REALTIME_ROUTE_STORE_URL=redis://127.0.0.1:6379
# SDKWORK_IM_REALTIME_TCP_BIND_ADDR=127.0.0.1:18090
# SDKWORK_IM_REALTIME_UDP_BIND_ADDR=127.0.0.1:18091
# SDKWORK_IM_REALTIME_QUIC_BIND_ADDR=127.0.0.1:18092
# SDKWORK_IM_REALTIME_QUIC_TLS_CERT_PATH=/path/to/quic-cert.pem
# SDKWORK_IM_REALTIME_QUIC_TLS_KEY_PATH=/path/to/quic-key.pem
# SDKWORK_IM_REALTIME_MAX_LINK_CONNECTIONS=10000
