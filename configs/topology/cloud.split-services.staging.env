# cloud.split-services.staging
SDKWORK_IM_DEPLOYMENT_PROFILE=cloud
SDKWORK_IM_SERVICE_LAYOUT=split-services
SDKWORK_IM_ENVIRONMENT=staging
SDKWORK_IM_PROFILE_ID=cloud.split-services.staging

SDKWORK_IM_APPLICATION_PUBLIC_HTTP_URL=https://im-staging.sdkwork.com
SDKWORK_IM_APPLICATION_PUBLIC_WEBSOCKET_URL=wss://im-staging.sdkwork.com
SDKWORK_IM_PLATFORM_API_GATEWAY_HTTP_URL=https://api-staging.sdkwork.com
SDKWORK_IM_PLATFORM_API_GATEWAY_AUTOSTART=false

SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=db-staging.example.com
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_prod_im_staging
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_PASSWORD_FILE=/run/secrets/sdkwork/database-password
SDKWORK_CLAW_DATABASE_SSL_MODE=require
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=24

VITE_SDKWORK_IM_DEPLOYMENT_PROFILE=cloud
VITE_SDKWORK_IM_APPLICATION_PUBLIC_HTTP_URL=https://im-staging.sdkwork.com
VITE_SDKWORK_IM_APPLICATION_PUBLIC_WEBSOCKET_URL=wss://im-staging.sdkwork.com
VITE_SDKWORK_IM_PLATFORM_API_GATEWAY_HTTP_URL=https://api-staging.sdkwork.com

SDKWORK_IM_APP_CONTEXT_REQUIRE_SIGNATURE=true
SDKWORK_IM_APP_CONTEXT_SIGNATURE_SECRET=/run/secrets/sdkwork/app-context-signature-secret
SDKWORK_IM_APP_CONTEXT_JWT_TENANT_ID=replace-with-staging-tenant-id
SDKWORK_IM_APP_CONTEXT_JWT_KEY_ID=bootstrap
SDKWORK_IM_APP_CONTEXT_JWT_SIGNING_SECRET=/run/secrets/sdkwork/jwt-signing-secret
SDKWORK_API_CLOUD_GATEWAY_CONFIG=configs/sdkwork-api-cloud-gateway.sdkwork-im.production.toml
