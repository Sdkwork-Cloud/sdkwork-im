{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifacts/releases/schemas/server-release-gate.schema.json",
  "title": "sdkwork-im server release gate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "bundleId",
    "wave",
    "artifact",
    "state",
    "decisionStatus",
    "updatedAt",
    "releaseChecklistPath",
    "packageCatalogPath",
    "releaseExecutionPath",
    "releaseProvenancePath",
    "reviewDocPaths",
    "gateChecks",
    "platformGateChecks"
  ],
  "properties": {
    "$schema": {
      "const": "../../schemas/server-release-gate.schema.json"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "wave": {
      "type": "string",
      "minLength": 1
    },
    "artifact": {
      "const": "server-release-gate"
    },
    "state": {
      "type": "string",
      "enum": [
        "template_only_pending_evaluation",
        "ready_for_go_no_go",
        "go_approved",
        "no_go"
      ]
    },
    "decisionStatus": {
      "type": "string",
      "enum": [
        "pending_go_no_go",
        "go",
        "no_go"
      ]
    },
    "updatedAt": {
      "type": "string",
      "format": "date"
    },
    "releaseChecklistPath": {
      "type": "string",
      "minLength": 1
    },
    "packageCatalogPath": {
      "type": "string",
      "minLength": 1
    },
    "releaseExecutionPath": {
      "type": "string",
      "minLength": 1
    },
    "releaseProvenancePath": {
      "type": "string",
      "minLength": 1
    },
    "reviewDocPaths": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "gateChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gateId",
          "description",
          "contractPath",
          "status",
          "blocking"
        ],
        "properties": {
          "gateId": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "contractPath": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending_validation",
              "satisfied",
              "failed"
            ]
          },
          "blocking": {
            "type": "boolean"
          }
        }
      }
    },
    "platformGateChecks": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "platform",
          "acceptanceManifestPath",
          "requiredPackageIds",
          "status"
        ],
        "properties": {
          "platform": {
            "type": "string",
            "enum": [
              "linux",
              "macos",
              "windows"
            ]
          },
          "acceptanceManifestPath": {
            "type": "string",
            "minLength": 1
          },
          "requiredPackageIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "pending_validation",
              "satisfied",
              "failed"
            ]
          }
        }
      }
    }
  }
}
