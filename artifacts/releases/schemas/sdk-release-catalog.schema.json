{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifacts/releases/schemas/sdk-release-catalog.schema.json",
  "title": "sdkwork-im sdk release catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "bundleId",
    "wave",
    "artifact",
    "state",
    "updatedAt",
    "sdkArtifacts"
  ],
  "properties": {
    "$schema": {
      "const": "../schemas/sdk-release-catalog.schema.json"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "wave": {
      "type": "string",
      "minLength": 1
    },
    "artifact": {
      "const": "sdk-release-catalog"
    },
    "state": {
      "type": "string",
      "enum": [
        "template_only_pending_generation",
        "generated_pending_publication",
        "published"
      ]
    },
    "updatedAt": {
      "type": "string",
      "format": "date"
    },
    "sdkArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "audience",
          "language",
          "package",
          "readmePath",
          "plannedVersion",
          "versionStatus",
          "versionDecisionSourcePath",
          "generationStatus",
          "releaseStatus"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "audience": {
            "type": "string",
            "minLength": 1
          },
          "language": {
            "type": "string",
            "minLength": 1
          },
          "package": {
            "type": "string",
            "minLength": 1
          },
          "readmePath": {
            "type": "string",
            "minLength": 1
          },
          "plannedVersion": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "versionStatus": {
            "type": "string",
            "enum": [
              "version_unassigned_pending_freeze",
              "version_frozen"
            ]
          },
          "versionDecisionSourcePath": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "generationStatus": {
            "type": "string",
            "enum": [
              "template_only_pending_generation",
              "generated"
            ]
          },
          "releaseStatus": {
            "type": "string",
            "enum": [
              "not_published",
              "published"
            ]
          }
        }
      }
    }
  }
}
