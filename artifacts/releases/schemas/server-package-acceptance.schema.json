{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifacts/releases/schemas/server-package-acceptance.schema.json",
  "title": "sdkwork-im server package acceptance manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "bundleId",
    "platform",
    "artifact",
    "artifactRoot",
    "validationStatus",
    "updatedAt",
    "packageChecks"
  ],
  "properties": {
    "$schema": {
      "const": "../../../../../schemas/server-package-acceptance.schema.json"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "enum": [
        "linux",
        "macos",
        "windows"
      ]
    },
    "artifact": {
      "const": "server-package-acceptance-manifest"
    },
    "artifactRoot": {
      "type": "string",
      "minLength": 1
    },
    "validationStatus": {
      "type": "string",
      "enum": [
        "template_only_pending_execution",
        "validated_ready_for_release",
        "released"
      ]
    },
    "updatedAt": {
      "type": "string",
      "format": "date"
    },
    "packageChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "packageId",
          "packageType",
          "artifactPath",
          "installModel",
          "serviceManager",
          "startupCommand",
          "requiredEntries",
          "validationEvidencePath",
          "status"
        ],
        "properties": {
          "packageId": {
            "type": "string",
            "minLength": 1
          },
          "packageType": {
            "type": "string",
            "enum": [
              "tar.gz",
              "deb",
              "rpm",
              "pkg",
              "zip",
              "msi"
            ]
          },
          "artifactPath": {
            "type": "string",
            "minLength": 1
          },
          "installModel": {
            "type": "string",
            "enum": [
              "archive",
              "native-installer"
            ]
          },
          "serviceManager": {
            "type": "string",
            "enum": [
              "systemd",
              "launchd",
              "windows-service"
            ]
          },
          "startupCommand": {
            "type": "string",
            "minLength": 1
          },
          "requiredEntries": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "validationEvidencePath": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending_validation",
              "validated"
            ]
          }
        }
      }
    }
  }
}
