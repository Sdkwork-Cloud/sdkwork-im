<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.sdkwork.im.server</string>

  <key>ProgramArguments</key>
  <array>
    <string>__INSTALL_ROOT__/bin/sdkwork-im-server</string>
    <string>--config</string>
    <string>__CONFIG_DIR__/server.yaml</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__INSTALL_ROOT__</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__LOG_DIR__/sdkwork-im-server.out.log</string>

  <key>StandardErrorPath</key>
  <string>__LOG_DIR__/sdkwork-im-server.err.log</string>
</dict>
</plist>
