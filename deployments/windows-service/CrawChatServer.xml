<service>
  <id>CrawChatServer</id>
  <name>CrawChatServer</name>
  <description>Craw Chat Server Windows Service wrapper</description>

  <executable>__INSTALL_ROOT__\bin\craw-chat-server.exe</executable>
  <arguments>--config &quot;__CONFIG_DIR__\chat.toml&quot;</arguments>

  <logpath>__LOG_DIR__</logpath>
  <log mode="roll" />

  <onfailure action="restart" delay="10 sec" />
</service>
