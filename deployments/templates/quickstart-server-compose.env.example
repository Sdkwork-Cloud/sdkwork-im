CRAW_CHAT_SERVER_IMAGE=ghcr.io/sdkwork/chat-server:latest
SDKWORK_CHAT_DEPLOYMENT_MODE=server
SDKWORK_CHAT_CONFIG_FILE=/etc/sdkwork/chat/chat.toml
SDKWORK_CHAT_DATA_DIR=/var/lib/sdkwork/chat
SDKWORK_CHAT_LOG_DIR=/var/log/sdkwork/chat
SDKWORK_CHAT_RUN_DIR=/run/sdkwork/chat
SDKWORK_CHAT_ID_NODE_ID=1
SDKWORK_CHAT_SERVER_BIND=0.0.0.0:18080
SDKWORK_CHAT_SERVER_BASE_URL=http://127.0.0.1:18080/sdkwork/chat
SDKWORK_CHAT_SERVER_API_BASE_URL=http://127.0.0.1:18080/sdkwork/chat
SDKWORK_CHAT_SERVER_WEBSOCKET_BASE_URL=ws://127.0.0.1:18080/sdkwork/chat
CRAW_CHAT_SERVER_BASE_URL=http://127.0.0.1:18080/sdkwork/chat
CRAW_CHAT_SERVER_API_BASE_URL=http://127.0.0.1:18080/sdkwork/chat
CRAW_CHAT_SERVER_WEBSOCKET_BASE_URL=ws://127.0.0.1:18080/sdkwork/chat
CRAW_CHAT_BROWSER_ORIGINS=http://127.0.0.1:18080,http://localhost:18080
CRAW_CHAT_PC_API_UPSTREAM=
CRAW_CHAT_APP_CONTEXT_REQUIRE_SIGNATURE=true
CRAW_CHAT_APP_CONTEXT_SIGNATURE_SECRET=replace-with-quickstart-app-context-signature-secret
SDKWORK_CHAT_DATABASE_ENGINE=postgresql
SDKWORK_CHAT_DATABASE_HOST=postgres
SDKWORK_CHAT_DATABASE_PORT=5432
SDKWORK_CHAT_DATABASE_NAME=sdkwork_chat_prod
SDKWORK_CHAT_DATABASE_SCHEMA=sdkwork_chat_prod
SDKWORK_CHAT_DATABASE_USERNAME=sdkwork_chat_prod
SDKWORK_CHAT_DATABASE_PASSWORD=replace-me
SDKWORK_CHAT_DATABASE_SSL_MODE=disable
CRAW_CHAT_POSTGRES_HOST=postgres
CRAW_CHAT_POSTGRES_DATABASE=sdkwork_chat_prod
