SDKWORK_IM_SERVER_IMAGE=ghcr.io/sdkwork/chat-server:latest
SDKWORK_IM_DEPLOYMENT_MODE=server
SDKWORK_IM_CONFIG_FILE=/etc/sdkwork/chat/chat.toml
SDKWORK_IM_DATA_DIR=/var/lib/sdkwork/chat
SDKWORK_IM_LOG_DIR=/var/log/sdkwork/chat
SDKWORK_IM_RUN_DIR=/run/sdkwork/chat
SDKWORK_IM_ID_NODE_ID=1
SDKWORK_IM_APPLICATION_PUBLIC_INGRESS_BIND=0.0.0.0:18080
SDKWORK_IM_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18080
SDKWORK_IM_APPLICATION_PUBLIC_WEBSOCKET_URL=ws://127.0.0.1:18080
SDKWORK_IM_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_IM_BROWSER_ORIGINS=http://127.0.0.1:18080,http://localhost:18080
SDKWORK_IM_PC_API_UPSTREAM=
SDKWORK_IM_APP_CONTEXT_REQUIRE_SIGNATURE=true
SDKWORK_IM_APP_CONTEXT_SIGNATURE_SECRET=replace-with-quickstart-app-context-signature-secret
SDKWORK_IM_DATABASE_ENGINE=postgresql
SDKWORK_IM_DATABASE_HOST=postgres
SDKWORK_IM_DATABASE_PORT=5432
SDKWORK_IM_DATABASE_NAME=sdkwork_chat_prod
SDKWORK_IM_DATABASE_SCHEMA=sdkwork_chat_prod
SDKWORK_IM_DATABASE_USERNAME=sdkwork_chat_prod
SDKWORK_IM_DATABASE_PASSWORD=replace-me
SDKWORK_IM_DATABASE_SSL_MODE=disable
SDKWORK_IM_POSTGRES_HOST=postgres
SDKWORK_IM_POSTGRES_DATABASE=sdkwork_chat_prod
