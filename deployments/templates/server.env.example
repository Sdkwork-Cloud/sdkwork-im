CRAW_CHAT_SERVER_INSTANCE=default
CRAW_CHAT_SERVER_CONFIG_DIR=/etc/craw-chat/default
CRAW_CHAT_SERVER_DATA_DIR=/var/lib/craw-chat/default
CRAW_CHAT_SERVER_LOG_DIR=/var/log/craw-chat/default
CRAW_CHAT_SERVER_RUN_DIR=/var/run/craw-chat/default
CRAW_CHAT_SERVER_BIND_ADDRESS=0.0.0.0:18080
CRAW_CHAT_SERVER_BASE_URL=https://chat.example.com
CRAW_CHAT_SERVER_API_BASE_URL=https://chat.example.com
CRAW_CHAT_SERVER_WEBSOCKET_BASE_URL=wss://realtime.example.com/im/v3/api/realtime/ws
CRAW_CHAT_SERVER_IMAGE=ghcr.io/sdkwork/craw-chat-server:latest
