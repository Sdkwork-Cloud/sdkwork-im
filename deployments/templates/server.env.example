CRAW_CHAT_SERVER_LOG_DIR=/var/log/craw-chat/default
CRAW_CHAT_SERVER_RUN_DIR=/var/run/craw-chat/default
CRAW_CHAT_SERVER_BIND_ADDRESS=0.0.0.0:18080
CRAW_CHAT_SERVER_BASE_URL=https://chat.example.com
